# Local dev (spec 42). Gitignored — do not commit.
# Route the client API stack through the Vite dev proxy.
VITE_API_BASE_URL=/api
# Backend host the dev proxy forwards /api to, and that raw direct-backend
# calls (streaming /chat, /ask, /profile/company) target.
# Use 127.0.0.1 (NOT localhost): on Windows, Node/Vite resolves "localhost" to
# IPv6 ::1 first, but uvicorn binds IPv4 127.0.0.1 only -> ECONNREFUSED -> the
# proxy surfaces it as a 500. Forcing IPv4 here makes the proxy reach uvicorn.
VITE_BACKEND_BASE_URL=http://127.0.0.1:8000
