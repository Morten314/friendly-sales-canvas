# Frontend build-time environment contract (spec 42). Copy to frontend/.env for
# local dev. Vite inlines VITE_* vars at build time, so deployed values are set
# in the Vercel project's Environment Variables, NOT committed here.

# Local dev: route the client API stack through the Vite dev proxy.
VITE_API_BASE_URL=/api
# Backend host the dev proxy forwards /api to, and that the raw direct-backend
# calls (streaming /chat, /ask, /profile/company) target.
VITE_BACKEND_BASE_URL=http://localhost:8000

# Deployed (Vercel) — set these in the Vercel project for each environment.
# There is no /api rewrite in deployed builds (spec 42 D3), so VITE_API_BASE_URL
# must be the FULL backend base URL, not /api:
#   VITE_API_BASE_URL=https://<render-host>
#   VITE_BACKEND_BASE_URL=https://<render-host>
